# Figures
figures/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# uv (keep uv.lock — it's the lockfile)
.uv/

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Reconstruction pipeline outputs (regenerated by scripts/run_r2_route22_sb.py)
out/
out_*/
out_compare*.html
*.html
# Exception: dashboard HTML shells ship as source assets.
!scripts/dashboard/assets/*_index.html
# Exception: observation_tool is a web app — all its HTML is source.
!observation_tool/**/*.html

# Standalone diagnostic plots emitted at the repo root by exploratory scripts
timespace_*.png
mapmatching_example.png
trip_*.png

# Large GTFS downloads — re-fetched on demand by observation_tool/scripts/build_stops.py
cta_gtfs.zip
gtfs_*.zip

# R2 hour-file cache — re-fetched on demand from the public R2 URL by scripts/build_*.py
r2_cache/

# Raw data
ROCKET*.csv

# Intermediate per-script CSV exports (regenerated by scripts/build_*.py)
r2_route22_*.csv
cta_avl_archive_*.csv

# One-off Overpass / Valhalla scratch artifacts
freeflow_search_result.json
way_cache_route22.json

# Build / figure-rendering scripts kept locally only (every direct
# child of scripts/), with scripts/dashboard/ as an explicit exception
# below. We can't simply ignore "scripts/" because then git wouldn't
# recurse into the directory and the exception wouldn't apply.
scripts/*
# Exception: the interactive route dashboard (Python build + JS assets)
# IS tracked. It's a substantial deliverable, not a one-off figure
# script, so it gets versioned even though the surrounding scripts/ tree
# stays local-only.
!scripts/dashboard

# Externally-tracked subprojects
routing-valhalla/

# Original paper PDF (not redistributable)
Reconstructing_Transit_Vehicle_Trajectory_Using_High-Resolution_GPS_Data.pdf

# Office lock files
~\$*

# Reference PDFs and Claude Code session state — local-only.
docs/
.claude/

# Observation-tool build artifacts (rebuild via observation_tool/scripts/) and
# local Cloudflare secrets — never commit.
way_cache_all.json
cta_intersections_all.json
observation_tool/.dev.vars
# Cloudflare/Miniflare local dev state (local R2 blobs, sqlite, pages cache).
observation_tool/.wrangler/
# Generated comparison payloads (rebuilt by analysis/build_comparison.py) and
# downloaded bus-state-history CSVs — regenerable, not source.
observation_tool/analysis/dashboard/data/
observation_tool/analysis/AVL data/
