# --- Local data, outputs, and caches --------------------------------------
# All regenerable artifacts live under these three folders and are never
# committed (see README "Repository layout"):
#   data/    raw + intermediate inputs (GTFS zips, AVL/ROCKET/R2 CSVs,
#            diagnostic HTML/PNG scratch)
#   outputs/ reconstruction + decomposition bundles, dashboards, figures' inputs
#   caches/  realtime-archive hour-file cache + per-agency OSM way / intersection caches
data/
outputs/
caches/

# Figures: the curated report figure set under figures/ (families A1..H7) is
# tracked. Scripts also drop scratch / experimental PNGs there — ignore those.
figures/vtrak_smooth_*.png
figures/vtrak_speed_*.png
figures/rocket_vs_r2_*.png
figures/speed_pchip_vs_mqsi_*.png
figures/accel_pchip_vs_mqsi_*.png
figures/*_downtown_speed.png
figures/G_stem_along_route_*.png
figures/H_buffer_stem*.png
figures/H_stem_mean_only.png
figures/H_stem_with_congestion.png
figures/*_copy.png

# Stray HTML emitted by exploratory scripts. Exceptions: the dashboard HTML
# shells and the observation_tool web app (its HTML is all source).
*.html
!scripts/dashboard/assets/*_index.html
!observation_tool/**/*.html
!dashboard/**/*.html

# --- Externally-managed subprojects ---------------------------------------
routing-valhalla/

# --- Reference material (not redistributable) -----------------------------
docs/
Reconstructing_Transit_Vehicle_Trajectory_Using_High-Resolution_GPS_Data.pdf
~$*

# --- Claude Code session state --------------------------------------------
.claude/

# --- record-a-ride: secrets + build artifacts --------------------------
# Cloudflare secrets — never commit
record-a-ride/.dev.vars
# Miniflare local R2/sqlite/pages dev state (record-a-ride + dashboard deploys)
.wrangler/
# generated comparison payloads (rebuilt by analysis/comparison.py)
outputs/obs_trips/
# downloaded bus-state-history CSVs
analysis/AVL data/

# Merged dashboard payloads are built by analysis/ (Phase 6) or copied locally
dashboard/data/
