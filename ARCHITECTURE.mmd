%% reconstruct-bus-trajectories — layer / dependency architecture.
%% Source of truth for ARCHITECTURE.png. Render with:
%%   npx -y @mermaid-js/mermaid-cli -i ARCHITECTURE.mmd -o ARCHITECTURE.png -s 2
%% Solid = data / build flow; dashed = "serves"; colour = layer.
flowchart TD
    subgraph SRC["GPS-trace sources"]
        direction LR
        A1["R2 AVL archive"]
        A2["Record-a-Ride Pages backup API"]
        A3["phone GPS CSV"]
        A4["VTRAK list"]
    end

    subgraph DATAIO["dataio/ — external I/O (network · files)"]
        SRCS["sources/ — load_trace() → canonical trace"]
        IOMODS["gtfs · realtime (unified R2) · intersections · way_match · vtrak"]
        RECIO["records_io — reconstruct_csv · build_segments"]
    end

    subgraph CORE["src/core/ — pure business logic (no I/O, no plotting)"]
        COREMODS["smooth (LOCREG/PCHIP) · reconstruct · mapmatch · serialize · control_points"]
        DEC["decompose/ — events · dwell · attribution · loss · segments · travel_time · feature_attribution"]
    end

    subgraph ANALYSIS["analysis/ — results, prep helpers & payloads"]
        AMODS["prep/ (geometry · bands · speed · facility) · run_decomposition · data_prep/"]
        COMP["comparison.py — phone+R2+AVL fusion"]
        BUILD["build_dashboard_data — unified builder"]
    end

    subgraph FIGURES["figures/ — visualization"]
        FIGMODS["viz/ (plot · timespace · compare · colors) · scripts/ → A–H .png"]
    end

    subgraph DASH["dashboard/ — one merged app"]
        APP["app/ + views/ — Single trip (Trajectory · Speed) · Average trip (Overall · Segment)"]
        DATA[("data/ catalog — trips + aggregates")]
    end

    REC["record-a-ride/ — recording app + Cloudflare Pages functions (separate live deploy)"]
    CORRIDOR["corridor.py — one study-route config; scripts read it"]

    A1 --> SRCS
    A2 --> SRCS
    A3 --> SRCS
    A4 --> SRCS
    SRCS -->|canonical trace| CORE
    IOMODS --> CORE
    CORE --> ANALYSIS
    DATAIO --> ANALYSIS
    RECIO --> BUILD
    CORE --> FIGURES
    ANALYSIS --> FIGURES
    BUILD --> DATA
    COMP --> BUILD
    DATA --> APP
    REC -. serves .-> A2
    CORRIDOR -.-> CORE

    classDef dataio fill:#dbe7f6,stroke:#4a78b5;
    classDef core fill:#d7efdd,stroke:#3f9d5a;
    classDef analysis fill:#fce7cf,stroke:#d08a3a;
    classDef figures fill:#e7ddf6,stroke:#7b5aa6;
    classDef dash fill:#f7dada,stroke:#c05a5a;
    classDef rec fill:#e6e6e6,stroke:#888888;
    classDef src fill:#ffffff,stroke:#bbbbbb;
    classDef note fill:#fffdf0,stroke:#cbb76a,color:#776a2a;

    class A1,A2,A3,A4 src;
    class SRCS,IOMODS,RECIO dataio;
    class COREMODS,DEC core;
    class AMODS,COMP,BUILD analysis;
    class FIGMODS figures;
    class APP,DATA dash;
    class REC rec;
    class CORRIDOR note;
